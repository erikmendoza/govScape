# ==========================================
# Python Official Environment
# ==========================================
# Virtual environments
venv/
.venv/
env/
bin/
include/
lib/
share/

# Python Cache & Bytecode
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
dist/
build/
eggs/
*.egg-info/
*.egg

# ==========================================
# Data Lake (Local Only)
# ==========================================
# Ignore all data generated by pipelines.
# Raw, intermediate, and curated datasets should
# never be versioned in Git.

data/**

# Allow directory structure to be tracked
!data/**/

# Keep empty folders using .gitkeep
!data/**/.gitkeep


# ==========================================
# Logs & Execution Trace
# ==========================================
*.log
govscape_pipeline.log
logs/

# ==========================================
# Operating System Files
# ==========================================
# macOS (The "DS_Store" you mentioned)
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# Editor / IDE (VS Code, PyCharm)
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Environment Secrets (CRITICAL)
# ==========================================
.env
.venv